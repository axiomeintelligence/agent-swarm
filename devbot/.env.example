# ── Identity ──────────────────────────────────────────────────────────────────
# Container name — change when running multiple instances on the same host.
# Each instance also needs a unique HOST_PORT.
# Examples: devbot, devbot-alpha, devbot-research
CONTAINER_NAME=devbot

# ── GitHub ────────────────────────────────────────────────────────────────────
# [required] PAT used to clone your workspace repo at container startup.
# Needs repo read scope (public repos) or repo scope (private repos).
# Create at: https://github.com/settings/tokens
GITHUB_PAT=
GITHUB_REPO_URL=              # e.g. https://github.com/your-org/your-repo

# ── Claude Code ───────────────────────────────────────────────────────────────
# [optional] Plugins installed at container start (comma-separated, idempotent).
# Format: plugin-name@marketplace-name
# CLAUDE_PLUGINS=superpowers-extended-cc@superpowers-extended-cc-marketplace,github@claude-plugins-official,frontend-design@claude-plugins-official,skill-creator@claude-plugins-official,ui-ux-pro-max@ui-ux-pro-max-skill

# [optional] Git repo to clone as global Claude skills at startup.
# CLAUDE_SKILLS_REPO=

# ── MCP Servers ───────────────────────────────────────────────────────────────
# [optional] Cloudflare API token — registers 'cloudflare' MCP tool in Claude Code.
# CLOUDFLARE_API_TOKEN=

# ── Networking ────────────────────────────────────────────────────────────────
# [optional] Host port mapped to the claudecodeui web UI (container always uses 3001).
# Change this when running multiple instances.
HOST_PORT=3001

# [optional] Override where devbot stores Claude config and workspace data on the host.
# Defaults to ./data/claude and ./workspace relative to the devbot/ directory.
# CLAUDE_DIR=
# WORKSPACE_DIR=

# ── Runtime ───────────────────────────────────────────────────────────────────
TZ=UTC
# NODE_OPTIONS=--max-old-space-size=4096

# Root directory claudecodeui uses for project discovery inside the container.
WORKSPACES_ROOT=/workspace

# ── API (claudecodeui bearer auth) ────────────────────────────────────────────
# [optional] Secures the claudecodeui web UI. Leave blank to disable auth.
# Generate a token: openssl rand -hex 32
# API_BEARER_TOKEN=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# [optional] Claude Code API key. Set this OR authenticate interactively via the web UI.
# ANTHROPIC_API_KEY=
