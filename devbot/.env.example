# ── Identity ──────────────────────────────────────────────────────────────────
# Container name. Change for multiple instances on the same machine.
# Each instance also needs a unique DEVBOT_HOST_PORT.
# Examples: devbot, devbot-alpha, devbot-research
DEVBOT_NAME=devbot

# ── GitHub ────────────────────────────────────────────────────────────────────
# PAT used to clone your workspace repo at container startup.
# Needs repo read scope (public repos) or repo scope (private repos).
GITHUB_PAT=your_github_pat_here
GITHUB_REPO_URL=https://github.com/your-org/your-repo

# ── Claude Code ───────────────────────────────────────────────────────────────
# Plugins installed at container start (comma-separated, idempotent).
# Format: plugin-name@marketplace-name
CLAUDE_PLUGINS=superpowers-extended-cc@superpowers-extended-cc-marketplace,mem0@mem0-plugins,github@claude-plugins-official,frontend-design@claude-plugins-official,skill-creator@claude-plugins-official

# Optional: git clone a skills repo into ~/.claude/skills/ at startup.
# Skills in that repo become available to Claude Code automatically.
CLAUDE_SKILLS_REPO=

# ── MCP Servers ───────────────────────────────────────────────────────────────
# Cloudflare MCP server — registers 'cloudflare' MCP tool in Claude Code.
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# If set, cloudflared exposes the claudecodeui web UI via a named tunnel.
# Create a tunnel at dash.cloudflare.com > Zero Trust > Tunnels.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Networking ────────────────────────────────────────────────────────────────
# Host port mapped to the claudecodeui web UI (container always uses 3001).
# Change this when running multiple instances.
DEVBOT_HOST_PORT=3001

# Optional: override where devbot stores Claude config and workspace data on the host.
# Defaults to ./data/claude and ./workspace relative to the devbot/ directory.
DEVBOT_CLAUDE_DIR=
DEVBOT_WORKSPACE_DIR=

# ── Runtime ───────────────────────────────────────────────────────────────────
TZ=UTC
NODE_OPTIONS=--max-old-space-size=4096

# Root directory claudecodeui uses for project discovery inside the container.
WORKSPACES_ROOT=/workspace

# ── API (claudecodeui bearer auth) ────────────────────────────────────────────
# Secures the claudecodeui web UI. Leave blank to disable auth.
# Generate a token: openssl rand -hex 32
API_BEARER_TOKEN=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Claude Code API key. Set this OR authenticate interactively via the web UI.
ANTHROPIC_API_KEY=
