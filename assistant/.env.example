# ── Identity ──────────────────────────────────────────────────────────────────
# Container name. Change for multiple instances on the same machine.
# Each instance also needs a unique HOST_PORT.
CONTAINER_NAME=assistant

# ── Hermes gateway ────────────────────────────────────────────────────────────
# Port Hermes listens on for the web UI / API.
HOST_PORT=8642

# ── AI provider ───────────────────────────────────────────────────────────────
# One of: anthropic, openai, openrouter
AI_PROVIDER=anthropic

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# Used by Hermes when AI_PROVIDER=openai.
OPENAI_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Mono-repo ─────────────────────────────────────────────────────────────────
# Absolute path on the host where your mono-repo is cloned.
# Volumes for brain content, skills, and G-Brain state are mounted from here:
#   <MONO_REPO_PATH>/brain/         -> /brain-repo                (G-Brain knowledge source)
#   <MONO_REPO_PATH>/skills/        -> /opt/data/skills/mono (ro) (Hermes skills, category `mono`)
#   <MONO_REPO_PATH>/.gbrain-data/  -> G-Brain PGLite DB          (persistent state)
MONO_REPO_PATH=/path/to/your/mono-repo

# How often (seconds) to git-pull the mono-repo. One tick refreshes both
# the Hermes skills tree (auto-loaded on read) and re-imports brain/ into G-Brain.
SKILL_SYNC_INTERVAL=300

# ── Google Drive MCP ──────────────────────────────────────────────────────────
# Full JSON content of a Google service account key with Drive API access.
# Leave blank to disable Google Drive tools.
# Generate at: https://console.cloud.google.com/iam-admin/serviceaccounts
#   1. Create a service account
#   2. Grant "Drive API" access (or share specific folders with its email)
#   3. Create a key → JSON → paste the entire JSON here (single line)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Messaging platforms ───────────────────────────────────────────────────────
# Telegram — https://core.telegram.org/bots#creating-a-new-bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Slack — https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=

# ── Gmail IMAP/SMTP ───────────────────────────────────────────────────────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ALLOWED_USERS=
EMAIL_POLL_INTERVAL=15

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── Image overrides (consuming repos) ─────────────────────────────────────────
# Override to use locally-built or custom-tagged images.
# ASSISTANT_IMAGE=ghcr.io/axiomeintelligence/assistant:latest
# GDRIVE_MCP_IMAGE=ghcr.io/axiomeintelligence/gdrive-mcp:latest
