# ── Identity ──────────────────────────────────────────────────────────────────
# Container name. Change for multiple instances on the same machine.
# Each instance also needs a unique HOST_PORT.
CONTAINER_NAME=assistant

# ── Hermes gateway ────────────────────────────────────────────────────────────
# Port Hermes listens on for the web UI / API.
HOST_PORT=8642

# ── AI provider ───────────────────────────────────────────────────────────────
# One of: anthropic, openai, openrouter
AI_PROVIDER=anthropic

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# Used by Hermes when AI_PROVIDER=openai.
OPENAI_API_KEY=

# ── G-Brain knowledge graph ───────────────────────────────────────────────────
# G-Brain uses OpenAI specifically for embeddings. By default it inherits
# OPENAI_API_KEY above. Set GBRAIN_OPENAI_API_KEY to use a separate key —
# useful if you want Hermes on Anthropic/OpenRouter but still want embeddings,
# or to track G-Brain usage separately. Both can be set to the same key.
# Leave blank to disable embeddings (G-Brain runs without them).
GBRAIN_OPENAI_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Git ref to build G-Brain from. Accepts branch, tag, or full SHA.
# Pin to a SHA for reproducible builds. Default: main.
GBRAIN_REF=main

# ── Google Drive MCP ──────────────────────────────────────────────────────────
# Full JSON content of a Google service account key with Drive API access.
# Leave blank to disable Google Drive tools.
# Generate at: https://console.cloud.google.com/iam-admin/serviceaccounts
#   1. Create a service account
#   2. Grant "Drive API" access (or share specific folders with its email)
#   3. Create a key → JSON → paste the entire JSON here (single line)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Messaging platforms ───────────────────────────────────────────────────────
# Telegram — https://core.telegram.org/bots#creating-a-new-bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Slack — https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=

# ── Gmail IMAP/SMTP ───────────────────────────────────────────────────────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ALLOWED_USERS=
EMAIL_POLL_INTERVAL=15

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── Image overrides (consuming repos) ─────────────────────────────────────────
# Override to use locally-built or custom-tagged images.
# ASSISTANT_IMAGE=ghcr.io/axiomeintelligence/assistant:latest
# GBRAIN_IMAGE=ghcr.io/axiomeintelligence/gbrain:latest
# GDRIVE_MCP_IMAGE=ghcr.io/axiomeintelligence/gdrive-mcp:latest
