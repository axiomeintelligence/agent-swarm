# Hermes Standalone — Environment Variables
# Copy to .env and fill in values:
#   cp .env.example .env

# ── Container ────────────────────────────────────────────────────────────────
CONTAINER_NAME=hermes

# ── Ports ────────────────────────────────────────────────────────────────────
HOST_PORT=8642          # gateway API
DASHBOARD_PORT=9119     # dashboard UI

# ── AI Provider (at least one required) ──────────────────────────────────────
ANTHROPIC_API_KEY=      # required for Claude models
# OPENAI_API_KEY=       # optional — alternate AI provider
# OPENROUTER_API_KEY=   # optional — alternate AI provider

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=               # required for Telegram
# TELEGRAM_ALLOWED_USERS=         # optional — comma-separated usernames

# ── Slack ────────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=                # required for Slack
# SLACK_APP_TOKEN=                # required for Slack
# SLACK_ALLOWED_USERS=            # optional — comma-separated usernames

# ── Email / Gmail ─────────────────────────────────────────────────────────────
# EMAIL_ADDRESS=                  # required for email
# EMAIL_PASSWORD=                 # required for email (Gmail: use App Password)
# EMAIL_IMAP_HOST=imap.gmail.com  # optional — defaults to Gmail
# EMAIL_IMAP_PORT=993             # optional — defaults to 993
# EMAIL_SMTP_HOST=smtp.gmail.com  # optional — defaults to Gmail
# EMAIL_SMTP_PORT=587             # optional — defaults to 587
# EMAIL_ALLOWED_USERS=            # optional — comma-separated addresses
# EMAIL_POLL_INTERVAL=15          # optional — seconds, defaults to 15

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=UTC
