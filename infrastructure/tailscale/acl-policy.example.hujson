// Tailscale ACL Policy — agent-swarm deployment template
// Paste into: https://login.tailscale.com/admin/acls
//
// Tags must be declared in tagOwners before they can be applied to machines
// or used in ACL rules.
//
// How to apply tag:agent-server to a new server:
//   When generating the Tailscale auth key (SERVER_SETUP.md Step 1.3),
//   expand "Tags" and add "tag:agent-server". The server joins pre-tagged.
//
// How to apply tag:ci to GitHub Actions:
//   Create a separate auth key: ephemeral + preauthorized + tag:ci.
//   Store it as TAILSCALE_AUTH_KEY in your GitHub repository secrets.

{
  // Declare tags. Only admins can tag machines with these tags.
  "tagOwners": {
    "tag:agent-server": ["autogroup:admin"],
    "tag:ci":           ["autogroup:admin"]
  },

  "acls": [
    // Admins reach everything on the Tailnet.
    { "action": "accept", "src": ["autogroup:admin"], "dst": ["*:*"] },

    // Agent servers can reach the internet (Docker pulls, cloudflared, Tailscale relay).
    { "action": "accept", "src": ["tag:agent-server"], "dst": ["*:*"] },

    // GitHub Actions runners can only call the Komodo API (port 9120).
    // No SSH, no other ports.
    { "action": "accept", "src": ["tag:ci"], "dst": ["tag:agent-server:9120"] }
  ],

  // Tailscale SSH replaces OpenSSH per SERVER_SETUP.md.
  // cloud_user only — elevate to root via sudo after connecting.
  "ssh": [
    {
      "action": "accept",
      "src":    ["autogroup:admin"],
      "dst":    ["tag:agent-server"],
      "users":  ["cloud_user"]
    }
  ]
}
